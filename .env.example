# Copy this file to .env for local development. Never commit .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_CLASSIFICATION_PROMPT=Classify a message that arrived in Outlook Junk Email. Move to Inbox only for legitimate provider login-code or verification-code emails. Use spam_harmful for clear phishing, malware, extortion, credential theft, or scams. If uncertain, choose junk_keep. Return only the requested structured JSON.

# Microsoft Graph authentication.
# Use delegated refresh-token auth, or app-only auth with MAILBOX_USER_ID.
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
MAILBOX_USER_ID=

# Public cloud URL for Microsoft Graph webhook notifications.
GRAPH_NOTIFICATION_URL=https://your-cloud-host.example.com/webhooks/graph
GRAPH_CLIENT_STATE=replace-with-a-long-random-secret

# Local storage and admin protection.
DATABASE_PATH=spam_filter.sqlite3
ADMIN_TOKEN=replace-with-a-long-random-admin-token
ENVIRONMENT=development

# Classification thresholds.
INBOX_CONFIDENCE_THRESHOLD=0.92
DELETE_CONFIDENCE_THRESHOLD=0.88
PROVIDER_ALLOWLIST_PATH=providers.json
